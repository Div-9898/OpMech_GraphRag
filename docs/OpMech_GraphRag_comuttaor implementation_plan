    # Final answer
    print(f"\n{'─' * 70}")
    print("FINAL ANSWER")
    print(f"{'─' * 70}")
    print(f"\n{result.answer}")
    
    print(f"\n{'─' * 70}")
    print(f"Reasoning: {result.reasoning}")
    print("═" * 70)


def export_trajectory_json(result: QueryResult, filepath: str):
