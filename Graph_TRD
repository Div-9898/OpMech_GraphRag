5.2.2 Expert Modules
Expert Module Interface
from abc import ABC, abstractmethod
from typing import List, Dict, Tuple
from dataclasses import dataclass

class BaseExpert(ABC):
    """Abstract base class for all experts."""

    def __init__(self, config: Dict):
        self.config = config
        self.name = self.__class__.__name__

    @abstractmethod
    def discover_edges(
        self,
        nodes: List[Node],
        embeddings: Dict[str, np.ndarray]
    ) -> List[Edge]:
        """
        Discover edges of this expert's type.

        Args:
            nodes: List of all nodes in the graph
            embeddings: Dict mapping node_id -> embedding vector

        Returns:
            List of discovered edges with confidence scores
        """
        pass

    @abstractmethod
    def evaluate(
        self,
        predictions: List[Edge],
        gold: List[Edge]
    ) -> Metrics:
        """
        Evaluate expert on gold standard.

        Args:
            predictions: Predicted edges
            gold: Gold standard edges

        Returns:
            Metrics object with precision, recall, F1
        """
        pass

    @property
    @abstractmethod
    def edge_types(self) -> List[str]:
        """Return edge types this expert discovers."""
        pass

    def get_confidence_threshold(self) -> float:
        """Minimum confidence to emit an edge."""
        return self.config.get('confidence_threshold', 0.5)

@dataclass
class Metrics:
    precision: float
    recall: float
    f1: float
    true_positives: int
    false_positives: int
    false_negatives: int
    confidence_calibration: float

5.2.3 Expert Algorithm Specifications

Expert 1: Cross-Reference Hunter
Purpose: Detect explicit references between document sections

class CrossReferenceHunter(BaseExpert):
    """
    Detects explicit cross-references in SEC filings.
    Examples: "See Note 3", "as discussed in Item 7", "refer to Part II"
    """

    # Regex patterns for reference detection
    REFERENCE_PATTERNS = [
        r'[Ss]ee\s+Note\s+(\d+)',
        r'[Ss]ee\s+Item\s+(\d+[A-Z]?)',
        r'[Rr]efer\s+to\s+(?:the\s+)?(.+?)\s+(?:section|discussion)',
        r'[Aa]s\s+(?:discussed|described|noted)\s+in\s+(.+?)(?:\.|,)',
        r'[Ss]ee\s+(?:the\s+)?[""](.+?)[""]',
        r'Part\s+(I{1,3}|IV),?\s+Item\s+(\d+)',
        r'[Dd]escribed\s+(?:below|above)\s+(?:in|under)\s+[""]?(.+?)[""]?',
    ]

    def discover_edges(self, nodes, embeddings):
        edges = []

        for source_node in nodes:
            if source_node.type not in [NodeType.TEXT_SECTION, NodeType.NOTE]:
                continue

            # Find all reference patterns in source text
            for pattern in self.REFERENCE_PATTERNS:
                matches = re.finditer(pattern, source_node.text)
                for match in matches:
                    reference_target = match.group(1)

                    # Find target node that matches the reference
                    target_node = self._resolve_reference(
                        reference_target,
                        nodes,
                        source_node.metadata['filing_id']
                    )

                    if target_node:
                        confidence = self._calculate_confidence(
                            source_node, target_node, match
                        )
                        edges.append(Edge(
                            source_id=source_node.id,
                            target_id=target_node.id,
                            edge_type=EdgeType.REFERS_TO,
                            confidence=confidence,
                            expert=self.name,
                            evidence=match.group(0)
                        ))

        return self._deduplicate(edges)

    def _resolve_reference(self, ref_text, nodes, filing_id):
