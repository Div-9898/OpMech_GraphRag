Expert 3: Temporal Linker
Purpose: Connect same entities/metrics across time periods

class TemporalLinker(BaseExpert):
    """
    Links the same financial items across time periods.
    Examples: Revenue FY2022 -> Revenue FY2023 -> Revenue FY2024
              Risk Factor about China in Q1 -> same topic in Q2
    """

    def discover_edges(self, nodes, embeddings):
        edges = []

        # Strategy 1: XBRL tag matching across periods
        edges.extend(self._link_by_xbrl_tag(nodes))

        # Strategy 2: Note number matching across filings
        edges.extend(self._link_by_note_number(nodes))

        # Strategy 3: High-similarity text across periods
        edges.extend(self._link_by_embedding_similarity(nodes, embeddings))

        return edges

    def _link_by_xbrl_tag(self, nodes):
        """Link nodes with same XBRL tag across periods."""
        edges = []

        # Group nodes by XBRL tag
        tag_groups = defaultdict(list)
        for node in nodes:
            if node.type == NodeType.FINANCIAL_LINE:
                tag = node.metadata.get('xbrl_tag')
                if tag:
                    tag_groups[tag].append(node)

        # Create temporal edges within each group
        for tag, group_nodes in tag_groups.items():
            # Sort by period
            sorted_nodes = sorted(group_nodes, key=lambda n: n.metadata['period'])

            for i in range(len(sorted_nodes) - 1):
                edges.append(Edge(
                    source_id=sorted_nodes[i].id,
                    target_id=sorted_nodes[i + 1].id,
                    edge_type=EdgeType.TEMPORAL_NEXT,
                    confidence=0.95,  # High confidence for exact XBRL match
                    expert=self.name,
                    evidence=f"Same XBRL tag: {tag}"
                ))

        return edges

    def _link_by_embedding_similarity(self, nodes, embeddings):
        """Link high-similarity nodes across different periods."""
        edges = []
        SIMILARITY_THRESHOLD = 0.90  # High threshold for temporal links

        # Group nodes by type and filing
        for node_type in NodeType:
            type_nodes = [n for n in nodes if n.type == node_type]

            # Compare nodes from different periods
            for i, node1 in enumerate(type_nodes):
                for node2 in type_nodes[i+1:]:
                    # Must be different periods
                    if node1.metadata['period'] == node2.metadata['period']:
                        continue

                    # Calculate similarity
                    sim = cosine_similarity(
                        embeddings[node1.id],
                        embeddings[node2.id]
                    )

                    if sim >= SIMILARITY_THRESHOLD:
                        # Determine temporal order
                        if node1.metadata['period'] < node2.metadata['period']:
                            src, tgt = node1, node2
                        else:
                            src, tgt = node2, node1

                        edges.append(Edge(
                            source_id=src.id,
                            target_id=tgt.id,
                            edge_type=EdgeType.TEMPORAL_NEXT,
                            confidence=float(sim),
                            expert=self.name,
                            evidence=f"Embedding similarity: {sim:.3f}"
                        ))

        return edges

    @property
    def edge_types(self):
        return [EdgeType.TEMPORAL_NEXT]

Expert 4: Table-Text Connector
Purpose: Link table data to explanatory text

class TableTextConnector(BaseExpert):
    """
    Connects table rows to text that explains them.
    Examples: Table showing revenue by segment <-> MD&A discussing segment performance
              Balance sheet line item <-> Note explaining the item
    """

    SIMILARITY_THRESHOLD = 0.80
    NUMERIC_MATCH_TOLERANCE = 0.05  # 5% tolerance for numeric matching

    def discover_edges(self, nodes, embeddings):
        edges = []

        # Get table nodes and text nodes
        table_nodes = [n for n in nodes if n.type in
                       [NodeType.TABLE_ROW, NodeType.FINANCIAL_LINE]]
        text_nodes = [n for n in nodes if n.type in
                      [NodeType.TEXT_SECTION, NodeType.NOTE]]

        for table_node in table_nodes:
            # Strategy 1: Numeric value matching
            if table_node.metadata.get('value'):
                text_matches = self._find_numeric_matches(
                    table_node, text_nodes
                )
                edges.extend(text_matches)

            # Strategy 2: Embedding similarity
            sim_matches = self._find_similar_text(
                table_node, text_nodes, embeddings
            )
            edges.extend(sim_matches)

            # Strategy 3: XBRL tag to Note reference
            if table_node.metadata.get('xbrl_tag'):
                note_matches = self._find_note_references(
                    table_node, text_nodes
                )
                edges.extend(note_matches)

        return self._deduplicate(edges)

    def _find_numeric_matches(self, table_node, text_nodes):
        """Find text nodes mentioning similar numeric values."""
        edges = []
        target_value = table_node.metadata['value']

        for text_node in text_nodes:
            # Extract numbers from text
            numbers = re.findall(r'\$?([\d,]+(?:\.\d+)?)\s*(?:million|billion)?',
                                 text_node.text)

            for num_str in numbers:
                try:
                    num = float(num_str.replace(',', ''))
                    # Check for match within tolerance
                    if abs(num - target_value) / target_value <= self.NUMERIC_MATCH_TOLERANCE:
                        edges.append(Edge(
                            source_id=text_node.id,
                            target_id=table_node.id,
                            edge_type=EdgeType.EXPLAINS_LINE_ITEM,
                            confidence=0.85,
                            expert=self.name,
                            evidence=f"Numeric match: {num_str}"
                        ))
                except ValueError:
                    continue

        return edges

    def _find_similar_text(self, table_node, text_nodes, embeddings):
        """Find semantically similar text nodes."""
        edges = []
        table_emb = embeddings[table_node.id]

        for text_node in text_nodes:
            sim = cosine_similarity(table_emb, embeddings[text_node.id])

            if sim >= self.SIMILARITY_THRESHOLD:
                edges.append(Edge(
                    source_id=text_node.id,
                    target_id=table_node.id,
                    edge_type=EdgeType.DISCUSSES,
                    confidence=float(sim),
                    expert=self.name,
                    evidence=f"Semantic similarity: {sim:.3f}"
                ))

        return edges

    @property
    def edge_types(self):
        return [EdgeType.EXPLAINS_LINE_ITEM, EdgeType.DISCUSSES]

Expert 5: Semantic Bridge
Purpose: Connect semantically similar content and ensure connectivity

class SemanticBridge(BaseExpert):
    """
    Creates edges between semantically similar nodes.
    Also serves as fallback to ensure graph connectivity.
    """

    SIMILARITY_THRESHOLD = 0.85      # For SEMANTICALLY_SIMILAR edges
    BRIDGE_THRESHOLD = 0.70          # Lower threshold for connectivity bridges

    def discover_edges(self, nodes, embeddings):
        edges = []

        # Strategy 1: High-similarity pairs (same filing)
        edges.extend(self._find_similar_pairs_within_filing(nodes, embeddings))

        # Strategy 2: Cross-filing similarity (for related topics)
        edges.extend(self._find_cross_filing_similar(nodes, embeddings))

        return edges

    def _find_similar_pairs_within_filing(self, nodes, embeddings):
        """Find semantically similar nodes within same filing."""
        edges = []

        # Group by filing
        filing_groups = defaultdict(list)
        for node in nodes:
            filing_groups[node.metadata['filing_id']].append(node)

        for filing_id, filing_nodes in filing_groups.items():
            # Compare all pairs (with early stopping for efficiency)
            for i, node1 in enumerate(filing_nodes):
                for node2 in filing_nodes[i+1:]:
                    # Skip if same type and adjacent (likely already connected)
                    if (node1.type == node2.type and
                        abs(node1.metadata.get('char_offset', 0) -
                            node2.metadata.get('char_offset', 0)) < 1000):
                        continue

                    sim = cosine_similarity(
                        embeddings[node1.id],
                        embeddings[node2.id]
                    )

                    if sim >= self.SIMILARITY_THRESHOLD:
                        edges.append(Edge(
                            source_id=node1.id,
                            target_id=node2.id,
                            edge_type=EdgeType.SEMANTICALLY_SIMILAR,
                            confidence=float(sim),
                            expert=self.name,
                            evidence=f"Cosine similarity: {sim:.3f}"
                        ))

        return edges

    def _find_cross_filing_similar(self, nodes, embeddings):
        """Find similar nodes across different filings."""
        # Similar to above but across filings
        # Used for connecting related topics across time
        pass

    @property
    def edge_types(self):
        return [EdgeType.SEMANTICALLY_SIMILAR, EdgeType.BRIDGE]

5.2.4 Connectivity Enforcer
Purpose: Guarantee single connected component

class ConnectivityEnforcer:
    """
    Ensures the graph is fully connected (single component).
    Adds minimal BRIDGE edges to connect disconnected components.
    """

    BRIDGE_SIMILARITY_THRESHOLD = 0.70

    def enforce_connectivity(
        self,
        nodes: List[Node],
        edges: List[Edge],
        embeddings: Dict[str, np.ndarray]
    ) -> List[Edge]:
        """
        Add bridge edges to ensure single connected component.

        Algorithm:
        1. Find all connected components
        2. While more than 1 component exists:
           a. Find best edge to connect two components
           b. Add edge and merge components
        3. Return list of added bridge edges

        Returns:
            List of BRIDGE edges added to ensure connectivity
        """
        # Build adjacency list
        adj = defaultdict(set)
        for edge in edges:
            adj[edge.source_id].add(edge.target_id)
            adj[edge.target_id].add(edge.source_id)

        # Find connected components using Union-Find
        components = self._find_components(nodes, adj)

        bridge_edges = []

        while len(components) > 1:
            best_edge = None
            best_score = 0
            best_pair = None

            # Find best edge to connect any two components
            for i, comp1 in enumerate(components):
                for comp2 in components[i+1:]:
                    # Find most similar node pair across components
                    for node1_id in comp1:
                        for node2_id in comp2:
                            sim = cosine_similarity(
                                embeddings[node1_id],
                                embeddings[node2_id]
                            )
                            if sim > best_score:
                                best_score = sim
                                best_edge = Edge(
                                    id=f"{node1_id}__BRIDGE__{node2_id}",
                                    source_id=node1_id,
                                    target_id=node2_id,
                                    edge_type=EdgeType.BRIDGE,
                                    confidence=float(sim),
                                    expert="ConnectivityEnforcer",
                                    evidence=f"Bridge edge (similarity: {sim:.3f})"
                                )
                                best_pair = (i, components.index(comp2))

            if best_edge and best_score >= self.BRIDGE_SIMILARITY_THRESHOLD:
                bridge_edges.append(best_edge)

                # Merge components
                merged = components[best_pair[0]] | components[best_pair[1]]
                components = [c for j, c in enumerate(components)
                             if j not in best_pair]
                components.append(merged)
            else:
                # Force connection even below threshold (last resort)
                if best_edge:
                    best_edge.metadata['forced'] = True
                    best_edge.confidence = max(0.5, best_score)
                    bridge_edges.append(best_edge)

                    merged = components[best_pair[0]] | components[best_pair[1]]
                    components = [c for j, c in enumerate(components)
                                 if j not in best_pair]
                    components.append(merged)

        return bridge_edges

    def _find_components(self, nodes, adj):
        """Find connected components using BFS."""
        visited = set()
        components = []

        for node in nodes:
            if node.id not in visited:
                component = set()
                queue = [node.id]

                while queue:
                    current = queue.pop(0)
                    if current in visited:
                        continue
                    visited.add(current)
                    component.add(current)

                    for neighbor in adj[current]:
                        if neighbor not in visited:
                            queue.append(neighbor)

                components.append(component)

        return components

    def verify_connectivity(self, nodes: List[Node], edges: List[Edge]) -> Dict:
        """
        Verify graph connectivity and return metrics.

        Returns:
            Dict with connectivity statistics
        """
        adj = defaultdict(set)
        for edge in edges:
            adj[edge.source_id].add(edge.target_id)
            adj[edge.target_id].add(edge.source_id)

        components = self._find_components(nodes, adj)

        # Calculate metrics
        isolated = [n.id for n in nodes if n.id not in adj or len(adj[n.id]) == 0]
        degrees = [len(adj[n.id]) for n in nodes]

        return {
            'connected_components': len(components),
            'is_connected': len(components) == 1,
            'total_nodes': len(nodes),
            'total_edges': len(edges),
            'isolated_nodes': len(isolated),
            'isolated_node_ids': isolated[:10],  # First 10 for debugging
            'average_degree': sum(degrees) / len(degrees) if degrees else 0,
            'max_degree': max(degrees) if degrees else 0,
            'min_degree': min(degrees) if degrees else 0,
            'largest_component_size': max(len(c) for c in components) if components else 0,
            'bridge_edges': len([e for e in edges if e.edge_type == EdgeType.BRIDGE]),
        }

