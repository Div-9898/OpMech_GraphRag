Expert 2: Causal Chain Builder
Purpose: Identify cause-effect relationships in financial narratives

class CausalChainBuilder(BaseExpert):
    """
    Identifies causal relationships in financial text.
    Examples: "Revenue increased due to iPhone sales"
              "Operating expenses rose, resulting in lower margins"
    """

    # Causal connectors with directionality
    CAUSAL_FORWARD = [  # A leads to B
        r'resulted\s+in', r'led\s+to', r'caused', r'drove',
        r'contributed\s+to', r'increased.*(?:due\s+to|because)',
        r'therefore', r'consequently', r'as\s+a\s+result',
    ]

    CAUSAL_BACKWARD = [  # B caused by A
        r'due\s+to', r'because\s+of', r'driven\s+by',
        r'attributed\s+to', r'as\s+a\s+result\s+of',
        r'resulting\s+from', r'caused\s+by',
    ]

    def discover_edges(self, nodes, embeddings):
        edges = []

        # Strategy 1: Pattern-based detection within sentences
        for node in nodes:
            if node.type != NodeType.TEXT_SECTION:
                continue

            sentences = self._split_sentences(node.text)
            for sent in sentences:
                causal_edges = self._extract_causal_from_sentence(
                    sent, node, nodes, embeddings
                )
                edges.extend(causal_edges)

        # Strategy 2: Cross-node causal inference using dependency parsing
        edges.extend(self._dependency_parse_causals(nodes))

        # Strategy 3: LLM-based extraction for complex cases (optional)
        if self.config.get('use_llm', False):
            edges.extend(self._llm_extract_causals(nodes))

        return self._deduplicate_and_filter(edges)

    def _extract_causal_from_sentence(self, sentence, source_node, nodes, embeddings):
        """Extract causal relations from a single sentence."""
        edges = []

        # Check for causal patterns
        for pattern in self.CAUSAL_FORWARD:
            if re.search(pattern, sentence, re.IGNORECASE):
                # Parse sentence to find cause and effect spans
                cause, effect = self._parse_cause_effect(sentence, pattern)

                # Find nodes that match cause and effect
                cause_node = self._find_matching_node(cause, nodes, embeddings)
