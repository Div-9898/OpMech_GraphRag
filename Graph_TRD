                if cause_node and effect_node:
                    edges.append(Edge(
                        source_id=cause_node.id,
                        target_id=effect_node.id,
                        edge_type=EdgeType.LEADS_TO,
                        confidence=0.75,
                        expert=self.name,
                        evidence=sentence[:500]
                    ))

        return edges

